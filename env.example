# Supabase Configuration
# Get these values from your Supabase project dashboard:
# https://app.supabase.com/project/YOUR-PROJECT/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous (public) API key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase service role key (for admin operations)
# ⚠️ IMPORTANT: This is a SECRET key - it should NEVER be exposed to the client
# Only use this in server-side code (Server Components, Server Actions)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# Setup Instructions:
# =====================================================
# 1. Copy this file to .env.local:
#    cp env.example .env.local
#
# 2. Replace the values above with your actual Supabase credentials
#    - Go to https://app.supabase.com
#    - Select your project
#    - Navigate to Settings → API
#    - Copy "Project URL" as NEXT_PUBLIC_SUPABASE_URL
#    - Copy "anon public" key as NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - Copy "service_role" key as SUPABASE_SERVICE_ROLE_KEY
#      (⚠️ Keep this secret! It bypasses Row Level Security)
#
# 3. Never commit .env.local to version control
#    (it's already in .gitignore)
#
# =====================================================
# Note: These are NEXT_PUBLIC_ variables which means
# they will be embedded in the client-side JavaScript
# bundle. Never use secret keys here!
# =====================================================
