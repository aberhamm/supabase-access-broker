# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public site URL (required for correct redirects in production)
NEXT_PUBLIC_APP_URL=https://auth-portal.yourdomain.com

# ============================================================================
# Auth feature flags (default OFF; set to 'true' to enable)
# ============================================================================
NEXT_PUBLIC_AUTH_PASSKEYS=false
NEXT_PUBLIC_AUTH_GOOGLE=false
NEXT_PUBLIC_AUTH_GITHUB=false
NEXT_PUBLIC_AUTH_EMAIL_OTP=false
NEXT_PUBLIC_AUTH_PASSWORD=false
NEXT_PUBLIC_AUTH_MAGIC_LINK=true

# Optional explicit auth portal URL / passkey RP ID
# (Defaults to NEXT_PUBLIC_APP_URL if not set)
NEXT_PUBLIC_AUTH_PORTAL_URL=https://auth-portal.yourdomain.com
NEXT_PUBLIC_AUTH_PASSKEY_RP_ID=auth-portal.yourdomain.com
