# Deployment Configuration
# Copy this to .env.deploy and fill in your VM details

# Required: Remote server settings
DEPLOY_HOST=your-server.example.com
DEPLOY_USER=ubuntu
DEPLOY_PATH=/opt/claims-admin

# Optional: SSH settings
DEPLOY_PORT=22
# DEPLOY_SSH_KEY=~/.ssh/id_rsa

# Optional: Docker image name
# IMAGE_NAME=claims-admin-dashboard
