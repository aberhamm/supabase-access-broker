# Docker Environment Variables Example
# Copy this file to .env.production for Docker deployments

# ==============================================================================
# REQUIRED - Supabase Configuration
# ==============================================================================

# Your Supabase Project URL
# Find at: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Anonymous/Public Key
# Find at: https://app.supabase.com/project/_/settings/api
# This is safe to expose in client-side code
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase Service Role Key
# Find at: https://app.supabase.com/project/_/settings/api
# ⚠️ WARNING: This key bypasses Row Level Security - NEVER expose to client!
# This should ONLY be used server-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================

# Node environment (should be 'production' for Docker deployments)
NODE_ENV=production

# Port the application runs on inside the container
# Default: 3050 (don't change unless you modify Dockerfile)
PORT=3050

# Hostname to bind to
# Default: 0.0.0.0 (allows external connections)
HOSTNAME=0.0.0.0

# Your production domain (required for correct redirects)
NEXT_PUBLIC_APP_URL=https://admin.yourdomain.com

# ==============================================================================
# Auth Feature Flags (default OFF; set to 'true' to enable)
# ==============================================================================
NEXT_PUBLIC_AUTH_PASSKEYS=false
NEXT_PUBLIC_AUTH_GOOGLE=false
NEXT_PUBLIC_AUTH_GITHUB=false
NEXT_PUBLIC_AUTH_EMAIL_OTP=false
NEXT_PUBLIC_AUTH_PASSWORD=false
NEXT_PUBLIC_AUTH_MAGIC_LINK=true

# Optional explicit auth portal URL / passkey RP ID
# (Defaults to NEXT_PUBLIC_APP_URL if not set)
# NEXT_PUBLIC_AUTH_PORTAL_URL=https://auth-portal.yourdomain.com
# NEXT_PUBLIC_AUTH_PASSKEY_RP_ID=auth-portal.yourdomain.com
# For multi-subdomain passkey support, use the parent domain:
# NEXT_PUBLIC_AUTH_PASSKEY_RP_ID=yourdomain.com

# ==============================================================================
# Database-Backed App Configuration
# ==============================================================================
# App cache TTL in milliseconds (default: 305000 = 5 minutes)
APP_CACHE_TTL=305000

# Fallback to TypeScript config if DB is empty (default: true)
USE_FALLBACK_CONFIG=true

# ==============================================================================
# QUICK START
# ==============================================================================
# 1. Get your Supabase credentials from:
#    https://app.supabase.com/project/_/settings/api
#
# 2. Copy this file:
#    cp .env.docker.example .env.production
#
# 3. Edit with your actual values:
#    nano .env.production
#
# 4. Build and deploy:
#    make build && make up
#
# 5. Access your app at:
#    http://localhost:3050
#
# For production deployment see: DOCKER_DEPLOYMENT.md
